# Frontend (Vite): safe to expose in browser.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_BUCKET=cetmed

# Supabase Edge Function secrets: set with `supabase secrets set ...`.
# Never expose these in Vite/browser variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MOODLE_URL=https://moodle.cetmed.cl
MOODLE_TOKEN=token-webservice-moodle
GETNET_LOGIN=tu-login-getnet
GETNET_SECRET_KEY=tu-secret-key-getnet
GETNET_ENDPOINT=https://checkout.getnet.cl
PUBLIC_SITE_URL=https://new.cetmed.cl
PUBLIC_SITE_ORIGINS=https://new.cetmed.cl,https://cetmed.cl
MAIL_WEBHOOK_URL=https://new.cetmed.cl/mail/send.php
MAIL_WEBHOOK_TOKEN=token-largo-seguro
MAIL_INTERNAL_TO=contacto@cetmed.cl

# Test-only. Use true only in staging/new.cetmed.cl while validating Moodle.
ENABLE_PAYMENT_SIMULATION=false
