# ── Strapi CMS ─────────────────────────────────────────
HOST=0.0.0.0
PORT=1337
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-salt-here
ADMIN_JWT_SECRET=your-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-salt

# SQLite (default for dev) — no extra config needed
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# PostgreSQL (production)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=cetmed
# DATABASE_USERNAME=cetmed
# DATABASE_PASSWORD=yourpassword

# ── Stripe ─────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# ── Frontend (Vite) ────────────────────────────────────
# prefix VITE_ so Vite exposes to browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Flow.cl (alternative payment for Chile) ────────────
# Uncomment and fill if using Flow instead of Stripe
# FLOW_API_KEY=your-flow-api-key
# FLOW_SECRET_KEY=your-flow-secret-key
# FLOW_MODE=sandbox  # or 'production'
