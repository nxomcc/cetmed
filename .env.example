# ── Database (Supabase PostgreSQL) ──────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
JWT_SECRET=your_jwt_secret_min_32_chars
PORT=3001

# ── Supabase API & Storage ──────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_BUCKET=cetmed

# ── Stripe ─────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# ── Frontend (Vite) ────────────────────────────────────
# prefix VITE_ so Vite exposes to browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Flow.cl (alternative payment for Chile) ────────────
# Uncomment and fill if using Flow instead of Stripe
# FLOW_API_KEY=your-flow-api-key
# FLOW_SECRET_KEY=your-flow-secret-key
# FLOW_MODE=sandbox  # or 'production'

# Moodle Web Services REST
MOODLE_URL=https://moodle.cetmed.cl
MOODLE_TOKEN=token-webservice-moodle

# Getnet Chile (Placetopay)
GETNET_LOGIN=tu-login-getnet
GETNET_SECRET_KEY=tu-secret-key-getnet
GETNET_ENDPOINT=https://checkout.getnet.cl

# Test-only. Keep false in production.
ENABLE_PAYMENT_SIMULATION=false
