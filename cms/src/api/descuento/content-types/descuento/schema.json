{
  "kind": "collectionType",
  "collectionName": "descuentos",
  "info": {
    "singularName": "descuento",
    "pluralName": "descuentos",
    "displayName": "Descuento"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "codigo": { "type": "string", "required": true, "unique": true },
    "tipo": {
      "type": "enumeration",
      "enum": ["porcentaje", "monto_fijo"],
      "required": true,
      "default": "porcentaje"
    },
    "valor": { "type": "decimal", "required": true },
    "activo": { "type": "boolean", "default": true },
    "fecha_expiracion": { "type": "datetime" },
    "limite_usos": { "type": "integer" },
    "usos_actuales": { "type": "integer", "default": 0 },
    "descripcion": { "type": "string" }
  }
}
