{
  "kind": "collectionType",
  "collectionName": "noticias",
  "info": {
    "singularName": "noticia",
    "pluralName": "noticias",
    "displayName": "Noticia",
    "description": "Blog y noticias CETMED"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "titulo": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "titulo", "required": true },
    "resumen": { "type": "text" },
    "contenido": { "type": "richtext" },
    "imagen": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "autor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "noticias"
    },
    "vistas": { "type": "integer", "default": 0 }
  }
}
