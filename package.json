{
  "name": "cetmed",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n API,APP -c cyan,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "backend": "npm run dev --prefix backend",
    "app": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "extract:old-courses": "node backend/src/import-old-courses.js --dry-run",
    "import:old-courses": "node backend/src/import-old-courses.js --import --upload-images",
    "import:old-courses:local-images": "node backend/src/import-old-courses.js --import --upload-images --image-dir scratch/old-wordpress-images",
    "install:all": "npm install --prefix frontend && npm install --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
